{
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "command": "npm run build",
        "output": "dist"
      }
    },
    {
      "src": "backend/api/demo_request.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    { "source": "/api/demo-request", "destination": "/backend/api/demo_request.py" },
    { "source": "/api/demo-request/(.*)", "destination": "/backend/api/demo_request.py" },
    { "source": "/((?!api/).*)", "destination": "/frontend/dist/$1" }
  ]
}
