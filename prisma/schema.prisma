// ============================================================
// LEAVE DOMAIN
// ============================================================

enum LeaveCategory {
  PAID
  UNPAID
  STATUTORY
  MEDICAL
  BEREAVEMENT
  PARENTAL
  SABBATICAL
  OTHER
}

enum LeaveRequestStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CANCELLED
  IN_PROGRESS
  COMPLETED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
}

model LeaveType {
  id                  String        @id @default(cuid())
  organizationId      String
  tenantId            String
  name                String
  code                String
  description         String?
  category            LeaveCategory
  maxDaysPerYear      Int           @default(0)
  minDaysRequired     Int           @default(0)
  requiresApproval    Boolean       @default(true)
  requiresMedicalCert Boolean       @default(false)
  attachmentRequired  Boolean       @default(false)
  isActive            Boolean       @default(true)
  createdAt           DateTime      @default(now())
  createdBy           String?
  updatedAt           DateTime      @updatedAt
  updatedBy           String?
  deletedAt           DateTime?
  deletedBy           String?
  deletionReason      String?

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leaveRequests LeaveRequest[]
  leaveBalances LeaveBalance[]

  @@unique([tenantId, organizationId, name])
  @@unique([tenantId, organizationId, code])
  @@index([tenantId])
  @@index([organizationId])
  @@index([isActive])
}

model LeaveBalance {
  id            String   @id @default(cuid())
  employeeId    String
  leaveTypeId   String
  tenantId      String
  year          Int
  allocatedDays Float    @default(0)
  usedDays      Float    @default(0)
