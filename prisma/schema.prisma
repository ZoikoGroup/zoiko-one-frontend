  RATING_UPDATED
  CALIBRATION_CREATED
  CALIBRATION_COMPLETED
  REVIEW_TEMPLATE_CREATED
  REVIEW_TEMPLATE_UPDATED
}

model PerformanceCycle {
  id            String                @id @default(cuid())
  name          String
  description   String?
  type          PerformanceCycleType  @default(ANNUAL)
  startDate     DateTime
  endDate       DateTime
  status        PerformanceCycleStatus @default(DRAFT)
