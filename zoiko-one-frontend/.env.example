# PostgreSQL connection string for the Zoiko One SaaS foundation
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Optional shadow database for Prisma migrate if you use it in CI
# SHADOW_DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/SHADOW_DB?schema=public"

# Required for JWT access tokens and refresh token hashing. Use at least 32 random characters.
JWT_SECRET="replace-with-a-secure-random-value-at-least-32-chars"

# Optional seed password for admin@zoiko.one. Defaults to ZoikoAdmin!2026 if omitted.
# SEED_ADMIN_PASSWORD="replace-before-shared-environments"
