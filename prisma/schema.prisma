// ═══════════════════════════════════════════════════════════════════
// Employee Engagement & Surveys domain
// ═══════════════════════════════════════════════════════════════════

enum EngagementSurveyStatus {
  DRAFT
  ACTIVE
  CLOSED
  ARCHIVED
}

enum EngagementSurveyType {
  EMPLOYEE_SATISFACTION
  PULSE
  FEEDBACK
  ONBOARDING
  EXIT
  CUSTOM
}

enum EngagementPulseType {
  WEEKLY
  BI_WEEKLY
  MONTHLY
  QUARTERLY
}

enum EngagementCampaignStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum EngagementCampaignScope {
  DEPARTMENT
  TEAM
  ORGANIZATION
  ALL
}

enum EngagementRecognitionAwardType {
  SPOT_AWARD
  MVP
  MILESTONE
  PEER_RECOGNITION
  MANAGER_CHOICE
  CUSTOM
}

enum EngagementSentimentType {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum EngagementActionPlanStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model EngagementSurvey {
  id              String                  @id @default(cuid())
  tenantId        String
  organizationId  String
  title           String
  description     String?
  surveyType      EngagementSurveyType    @default(EMPLOYEE_SATISFACTION)
  status          EngagementSurveyStatus  @default(DRAFT)
  totalResponses  Int                     @default(0)
  targetResponses Int                     @default(0)
  startDate       DateTime?
  endDate         DateTime?
  createdBy       String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  deletedAt       DateTime?

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([tenantId, organizationId, title])
  @@index([tenantId])
  @@index([organizationId])
  @@index([status])
  @@index([surveyType])
  @@index([tenantId, status, deletedAt])
  @@index([createdAt])
  @@index([deletedAt])
}

model EngagementSurveyTemplate {
  id              String                  @id @default(cuid())
  tenantId        String
  organizationId  String
  name            String
  description     String?
  surveyType      EngagementSurveyType    @default(EMPLOYEE_SATISFACTION)
  questionCount   Int                     @default(0)
  isActive        Boolean                 @default(true)
  createdBy       String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  deletedAt       DateTime?

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([tenantId, organizationId, name])
  @@index([tenantId])
  @@index([organizationId])
  @@index([surveyType])
  @@index([isActive])
  @@index([tenantId, deletedAt])
  @@index([createdAt])
  @@index([deletedAt])
}

model EngagementPulseSurvey {
  id              String                  @id @default(cuid())
  tenantId        String
  organizationId  String
  title           String
  description     String?
  pulseType       EngagementPulseType     @default(MONTHLY)
  status          EngagementSurveyStatus  @default(DRAFT)
  responseRate    Int                     @default(0)
  totalParticipants Int                   @default(0)
  startDate       DateTime?
  endDate         DateTime?
  createdBy       String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  deletedAt       DateTime?

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([tenantId, organizationId, title])
  @@index([tenantId])
  @@index([organizationId])
  @@index([pulseType])
  @@index([status])
  @@index([tenantId, status, deletedAt])
  @@index([createdAt])
  @@index([deletedAt])
}

model EngagementFeedbackCampaign {
  id              String                      @id @default(cuid())
  tenantId        String
  organizationId  String
  name            String
  description     String?
  scope           EngagementCampaignScope     @default(ALL)
  status          EngagementCampaignStatus    @default(DRAFT)
  totalFeedbacks  Int                         @default(0)
  targetFeedbacks Int                         @default(0)
  startDate       DateTime?
  endDate         DateTime?
  createdBy       String?
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt
  deletedAt       DateTime?

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([tenantId, organizationId, name])
  @@index([tenantId])
  @@index([organizationId])
  @@index([scope])
  @@index([status])
  @@index([tenantId, status, deletedAt])
  @@index([createdAt])
  @@index([deletedAt])
}

model EngagementRecognitionProgram {
  id              String                        @id @default(cuid())
  tenantId        String
  organizationId  String
  name            String
  description     String?
  awardType       EngagementRecognitionAwardType @default(SPOT_AWARD)
  totalAwards     Int                           @default(0)
  budget          Int                           @default(0)
  isActive        Boolean                       @default(true)
  createdBy       String?
  createdAt       DateTime                      @default(now())
  updatedAt       DateTime                      @updatedAt
  deletedAt       DateTime?

  tenant               Tenant                           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  organization         Organization                     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employeeRecognitions EngagementEmployeeRecognition[]

  @@unique([tenantId, organizationId, name])
  @@index([tenantId])
  @@index([organizationId])
  @@index([awardType])
  @@index([isActive])
  @@index([tenantId, deletedAt])
  @@index([createdAt])
  @@index([deletedAt])
}

model EngagementEmployeeRecognition {
  id              String                        @id @default(cuid())
  tenantId        String
  organizationId  String
  employeeId      String
  programId       String
  awardType       EngagementRecognitionAwardType @default(SPOT_AWARD)
  reason          String
  awardedBy       String?
  awardedAt       DateTime                      @default(now())
  createdAt       DateTime                      @default(now())
  deletedAt       DateTime?

  employee     Employee                     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  program      EngagementRecognitionProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  organization Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenant       Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([organizationId])
  @@index([employeeId])
  @@index([programId])
  @@index([awardType])
  @@index([awardedAt])
  @@index([tenantId, deletedAt])
  @@index([createdAt])
  @@index([deletedAt])
}

model EngagementScore {
  id              String   @id @default(cuid())
  tenantId        String
  organizationId  String
  department      String
  score           Int
  previousScore   Int?
  employeeCount   Int      @default(0)
  surveyedCount   Int      @default(0)
  period          String
  recordedAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  deletedAt       DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, organizationId, department, period])
  @@index([tenantId])
  @@index([organizationId])
  @@index([department])
  @@index([period])
  @@index([score])
  @@index([recordedAt])
  @@index([tenantId, deletedAt])
  @@index([createdAt])
  @@index([deletedAt])
}

model EngagementSentimentAnalysis {
  id              String                   @id @default(cuid())
  tenantId        String
  organizationId  String
  department      String
  sentimentType   EngagementSentimentType
  percentage      Int                      @default(0)
  responseCount   Int                      @default(0)
  keywords        Json?
  period          String
  recordedAt      DateTime                 @default(now())
  createdAt       DateTime                 @default(now())
  deletedAt       DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([organizationId])
  @@index([department])
  @@index([sentimentType])
  @@index([period])
  @@index([recordedAt])
  @@index([tenantId, deletedAt])
  @@index([createdAt])
  @@index([deletedAt])
}

model EngagementActionPlan {
  id              String                      @id @default(cuid())
  tenantId        String
  organizationId  String
  title           String
  description     String?
  priority        RequirementPriority         @default(MEDIUM)
  status          EngagementActionPlanStatus  @default(DRAFT)
  assignedTo      String?
  dueDate         DateTime?
  completedAt     DateTime?
  createdBy       String?
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt
  deletedAt       DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([organizationId])
  @@index([priority])
  @@index([status])
  @@index([dueDate])
  @@index([tenantId, status, deletedAt])
  @@index([createdAt])
  @@index([deletedAt])
}

// ============================================================
// Recruitment Domain — ZoikoHR
// ============================================================

// -----------------------------------------------------------
// JobOpening
// -----------------------------------------------------------

model JobOpening {
  id              String   @id @default(cuid())
  organizationId  String
  tenantId        String
  title           String
  departmentId    String
  location        String?
  employmentType  String
  minExperience   Int?
  maxExperience   Int?
  salaryMin       Int?
  salaryMax       Int?
  description     String?
  requirements    String?
  responsibilities String?
  status          String   @default("DRAFT")
  openingsCount   Int      @default(1)
  filledCount     Int      @default(0)
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedBy       String?
  updatedAt       DateTime @updatedAt
  deletedBy       String?
  deletedAt       DateTime?
  deletionReason  String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department   Department   @relation(fields: [departmentId], references: [id])
  candidates   Candidate[]
  interviews   Interview[]
  offers       Offer[]

  @@unique([tenantId, organizationId, title])
  @@index([tenantId])
  @@index([organizationId])
  @@index([departmentId])
  @@index([status])
  @@index([tenantId, status, deletedAt])
  @@index([createdAt])
  @@index([deletedAt])
}

// -----------------------------------------------------------
// Candidate
// -----------------------------------------------------------

model Candidate {
  id             String   @id @default(cuid())
  organizationId String
  tenantId       String
  jobOpeningId   String
  firstName      String
  lastName       String
  email          String
  phone          String?
  resumeUrl      String?
  coverLetter    String?
  source         String?
  status         String   @default("APPLIED")
  appliedDate    DateTime @default(now())
  rating         Float?
  notes          String?
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedBy      String?
  updatedAt      DateTime @updatedAt
  deletedBy      String?
  deletedAt      DateTime?
  deletionReason String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  jobOpening   JobOpening   @relation(fields: [jobOpeningId], references: [id])
  interviews   Interview[]
  offers       Offer[]

  @@unique([tenantId, organizationId, email])
  @@index([tenantId])
  @@index([organizationId])
  @@index([jobOpeningId])
  @@index([status])
  @@index([tenantId, status, deletedAt])
  @@index([email])
  @@index([appliedDate])
  @@index([createdAt])
  @@index([deletedAt])
}

// -----------------------------------------------------------
// Interview
// -----------------------------------------------------------

model Interview {
  id             String    @id @default(cuid())
  organizationId String
  tenantId       String
  candidateId    String
  jobOpeningId   String
  interviewers   String[]
  type           String
  scheduledAt    DateTime
  durationMin    Int?
  location       String?
  meetingLink    String?
  status         String    @default("SCHEDULED")
  feedback       String?
  rating         Float?
  createdBy      String?
  createdAt      DateTime  @default(now())
  updatedBy      String?
  updatedAt      DateTime  @updatedAt
  deletedBy      String?
  deletedAt      DateTime?
  deletionReason String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  candidate    Candidate    @relation(fields: [candidateId], references: [id])
  jobOpening   JobOpening   @relation(fields: [jobOpeningId], references: [id])

  @@index([tenantId])
  @@index([organizationId])
  @@index([candidateId])
  @@index([jobOpeningId])
  @@index([status])
  @@index([tenantId, status, deletedAt])
  @@index([scheduledAt])
  @@index([createdAt])
  @@index([deletedAt])
}

// -----------------------------------------------------------
// Offer
// -----------------------------------------------------------

model Offer {
  id             String    @id @default(cuid())
  organizationId String
  tenantId       String
  candidateId    String
  jobOpeningId   String
  salaryOffered  Float?
  benefits       String?
  offerLetterUrl String?
  status         String    @default("DRAFT")
  sentAt         DateTime?
  respondedAt    DateTime?
  expiryDate     DateTime?
  notes          String?
  createdBy      String?
  createdAt      DateTime  @default(now())
  updatedBy      String?
  updatedAt      DateTime  @updatedAt
  deletedBy      String?
  deletedAt      DateTime?
  deletionReason String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  candidate    Candidate    @relation(fields: [candidateId], references: [id])
  jobOpening   JobOpening   @relation(fields: [jobOpeningId], references: [id])

  @@index([tenantId])
  @@index([organizationId])
  @@index([candidateId])
  @@index([jobOpeningId])
  @@index([status])
  @@index([tenantId, status, deletedAt])
  @@index([createdAt])
  @@index([deletedAt])
}
