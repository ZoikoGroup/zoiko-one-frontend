// ============================================================
// Workforce Domain — ZoikoHR
// ============================================================
//
// This domain covers employee master data, employment history,
// status tracking, personal profiles, addresses, identities,
// emergency contacts, skills, probation, and compliance flags.
//
// Application-layer constraints:
//
// 1. Exactly one EmploymentRecord per employee with
//    (expiresAt IS NULL) at any time — enforced in service layer.
//
// 2. Employee.terminationDate >= Employee.joinDate (if set).
//
// 3. Only TERMINATED status can have terminationDate set.
//
// 4. At least one active identity document for all ACTIVE employees.
//
// 5. Employee.userId is OPTIONAL to support external workers
//    (contractors, gig workers) without platform User accounts.
//    For full-time employees, userId is created on hire.
//
// 6. PayrollProfile, LeaveRequest, PerformanceReview, Goal
//    are defined in their respective domain modules.
//
// Migration Note:
//   The existing ReportingRelationship model references User
//   as employee/manager. A future migration should update
//   these FKs to reference Employee instead, once all
//   platform integrations are updated.
// ============================================================

// -----------------------------------------------------------
// Enums
// -----------------------------------------------------------

enum EmployeeMasterStatus {
  ACTIVE
  ON_LEAVE
  SUSPENDED
  INACTIVE
  TERMINATED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
  TEMPORARY
}

enum TerminationReason {
  RESIGNATION
  TERMINATION
  RETIREMENT
  LAYOFF
  OTHER
}

enum EmployeeRecordStatus {
  ACTIVE
  PROBATION
  EXTENDED_LEAVE
  SUSPENDED
  NOTICE_PERIOD
  TERMINATED
}

enum EmploymentChangeReason {
  HIRE
  PROMOTION
  TRANSFER
  DEMOTION
  ROLE_CHANGE
  CONTRACT_RENEWAL
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
  PREFER_NOT_TO_SAY
}

enum AddressType {
  RESIDENTIAL
  MAILING
  WORK
  OTHER
}

enum IdentityDocumentType {
  PASSPORT
  NATIONAL_ID
  DRIVERS_LICENSE
  SSN
  VISA
  WORK_PERMIT
  I9
}

enum EmergencyContactRelationship {
  SPOUSE
  CHILD
  PARENT
  SIBLING
  FRIEND
  OTHER
}

enum WorkingHoursType {
  FULL_TIME
  PART_TIME
  CUSTOM
}

enum PaymentFrequency {
  MONTHLY
  SEMI_MONTHLY
  WEEKLY
  BI_WEEKLY
}

// -----------------------------------------------------------
// Employee
// -----------------------------------------------------------

model Employee {
  id                String               @id @default(cuid())
  tenantId          String
  organizationId    String
  userId            String?              @unique
  employeeId        String
  firstName         String
  lastName          String
  email             String
  personalEmail     String?
  phoneNumber       String?
  personalPhone     String?
  dateOfBirth       DateTime?
  gender            String?
  nationality       String?
  profilePhotoUrl   String?
  status            EmployeeMasterStatus @default(ACTIVE)
  employmentType    EmploymentType       @default(FULL_TIME)
  joinDate          DateTime
  terminationDate   DateTime?
  terminationReason TerminationReason?
  terminationNotes  String?
  createdAt         DateTime             @default(now())
  createdBy         String?
  updatedAt         DateTime             @updatedAt
  updatedBy         String?
  deletedAt         DateTime?
  deletedBy         String?
  deletionReason    String?

  tenant             Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  organization       Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user               User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  profile            EmployeeProfile?
  employmentRecords  EmploymentRecord[]     @relation("EmployeeEmploymentRecord")
  statusHistory      EmployeeStatusRecord[]
  historySnapshots   EmployeeHistory[]
  emergencyContacts  EmergencyContact[]
  addresses          EmployeeAddress[]
  identities         EmployeeIdentity[]
  skillProfiles      SkillProfile[]
  probations         Probation[]
  complianceFlags     GlobalComplianceFlags?
  subordinateRecords  EmploymentRecord[]    @relation("EmployeeSubordinate")
  documentReferences  EmployeeDocumentReference[]
  leaveRequests       LeaveRequest[]
  leaveBalances       LeaveBalance[]
  attendances         Attendance[]
  shiftAssignments    ShiftAssignment[]
  performanceReviews  PerformanceReview[] @relation("EmployeePerformance")
  reviewedReviews     PerformanceReview[] @relation("Reviewer")
  goals               Goal[]
  feedbackGiven       Feedback[]          @relation("FeedbackGiver")
  feedbackReceived    Feedback[]          @relation("EmployeeFeedback")
  selfReviews         SelfReview[]        @relation("SelfReviewEmployee")
  managerReviews      ManagerReview[]     @relation("ManagerReviewEmployee")
  managedReviews      ManagerReview[]     @relation("ManagerReviewer")
  peerReviewsGiven    PeerReview[]        @relation("PeerReviewer")
  peerReviewsReceived PeerReview[]        @relation("PeerReviewEmployee")
  ratings             Rating[]            @relation("RatingEmployee")
  ratingAdjustments   RatingAdjustment[]  @relation("CalibrationEmployee")
  managedGoals        Goal[]              @relation("GoalManager")
  policyAcknowledgements     PolicyAcknowledgement[]
  policyViolations           PolicyViolation[]
  trainingComplianceRecords  TrainingCompliance[]
  employeeRecognitions       EngagementEmployeeRecognition[]

  @@unique([tenantId, email])
  @@unique([organizationId, employeeId])
  @@index([tenantId])
  @@index([organizationId])
  @@index([userId])
  @@index([status])
  @@index([employmentType])
  @@index([joinDate])
  @@index([tenantId, status, deletedAt])
  @@index([createdAt])
  @@index([deletedAt])
}

// -----------------------------------------------------------
// EmployeeProfile
