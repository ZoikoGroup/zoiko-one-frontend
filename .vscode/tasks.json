{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Next.js: Run Dev Server",
      "type": "shell",
      "command": "npm run dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "next",
        "pattern": {
          "regexp": "^(.*)$",
          "file": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Ready.*|.*Ready in.*",
          "endsPattern": ".*Ready.*|.*Ready in.*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Run npm build",
      "type": "shell",
      "command": "npm run build",
      "isBackground": false,
      "problemMatcher": [
        "$tsc"
      ]
    }
  ]
}